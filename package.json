{
  "name": "marks",
  "version": "0.0.2",
  "scripts": {
    "dev": "web-ext run --config web-ext.config.mjs & nodemon -e css,html,json,js,ts,vue --watch src/ --exec \"npm run build-lite\"",
    "build-lite": "vite build",
    "build": "vue-tsc --noEmit && vite build && web-ext --config=web-ext.config.mjs build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@vueuse/components": "^13.5.0",
    "@vueuse/core": "^13.5.0",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@testing-library/vue": "^8.1.0",
    "@types/chrome": "^0.1.1",
    "@types/node": "^24.0.15",
    "@types/webextension-polyfill": "^0.12.3",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "eslint": "^9.31.0",
    "eslint-plugin-html": "^8.1.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-vue": "^10.3.0",
    "happy-dom": "^17.0.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vite": "^6.0.7",
    "vitest": "^3.2.0",
    "vue-tsc": "^3.0.3",
    "web-ext": "^8.9.0",
    "webextension-polyfill": "^0.12.0"
  }
}
